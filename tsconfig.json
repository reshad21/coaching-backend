{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],

    "module": "CommonJS",
    "moduleResolution": "node",

    "rootDir": "./src",
    "outDir": "./build",

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["../shared/*"]
    },

    "types": ["node"],
    "resolveJsonModule": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "noImplicitAny": true,

    "removeComments": true,
    "skipLibCheck": true,
    "sourceMap": true
  },

  "include": ["src/**/*", "prisma/**/*"],
  "exclude": ["node_modules", "build", "coverage", "logs", "docs", "__test__"]
}